# Snyk (https://snyk.io) policy file

version: v1.25.0

# ==============================================================================
# JAVA 11 COMPATIBILITY POLICY
# ==============================================================================
#
# MockServer maintains Java 11 as the minimum supported JVM version to maximize
# compatibility (~23% of Java projects still use Java 11 as of 2026).
#
# This policy is documented in AGENTS.md and is a deliberate architectural decision.
#
# CONSEQUENCE: Many security fixes require Java 17+ and cannot be applied.
#
# The following dependency upgrades are BLOCKED by the Java 11 requirement:
#   - Spring Framework 5.3.x → 6.x (requires Java 17, class version 61.0)
#   - Spring Boot 2.7.x → 3.x (requires Java 17)
#   - Jetty 9.4.x → 10.x/12.x (requires Java 17)
#   - Jakarta EE 8 → Jakarta EE 9+ (requires Java 17)
#   - OkHttp 4.x → 5.x (requires Java 17)
#
# All vulnerabilities below are ignored because:
#   1. Fixes require Java 17+ dependencies
#   2. Most are in test-only dependencies (mockserver-examples, mockserver-spring-test-listener)
#   3. Not shipped in production artifacts (mockserver-netty JAR)
#
# Expiration date: 2026-06-16 (6 weeks from creation, triggers review)
# ==============================================================================

ignore:
  # Spring Framework 5.3.39 vulnerabilities - fixes only available in Spring 6.x (requires Java 17+)
  SNYK-JAVA-ORGSPRINGFRAMEWORK-12008931:
    - '*':
        reason: 'Spring 6.x required for fix, but Spring 6.x requires Java 17+. MockServer targets Java 11.'
        expires: 2026-06-16T00:00:00.000Z
  
